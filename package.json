{
  "name": "@harmoniclabs/use-cardano-wallet",
  "author": "Harmonic Labs",
  "version": "0.0.1",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!src/test"
  ],
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "start": "tsdx watch",
    "build": "tsc --project tsconfig.json",
    "test": "tsdx test --passWithNoTests",
    "lint": "tsdx lint",
    "prepare": "npm run build",
    "size": "size-limit",
    "analyze": "size-limit --why"
  },
  "peerDependencies": {
    "react": ">=16"
  },
  "husky": {
    "hooks": {
      "pre-commit": "tsdx lint"
    }
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.0.0",
    "@types/react": "^18.0.17",
    "@types/react-dom": "^18.0.6",
    "husky": "^8.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "size-limit": "^8.0.1",
    "tsdx": "^2.0.0",
    "tslib": "^2.4.0",
    "typedoc-plugin-markdown": "^3.13.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@harmoniclabs/cbor": "^2.0.1",
    "@harmoniclabs/crypto": "^0.3.0",
    "@harmoniclabs/uint8array-utils": "^1.0.4",
    "immer": "^9.0.15",
    "zustand": "^4.0.0"
  }
}
